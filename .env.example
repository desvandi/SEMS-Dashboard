# SEMS Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# Required: Secret for signing auth cookies (HMAC-SHA256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=your-random-secret-here

# Google Apps Script Web App URL (the GAS backend endpoint)
GAS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Cookie security: set to 'false' when NOT using HTTPS/custom domain
# Set to 'true' (or omit) when using HTTPS with a custom domain
COOKIE_SECURE=false

# Optional: Site URL for CORS and redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000
